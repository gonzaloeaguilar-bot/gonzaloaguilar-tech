    "pdf": "node scripts/generate-pdf.js posts/latest.md",
    "qa-pdf": "node scripts/qa-pdf.js pdfs/latest.pdf",
    "resources": "node scripts/build-resources-page.js",
    "repurpose": "node scripts/repurpose.js posts/latest.md",
    "build-index": "node scripts/build-index.js",
    "build-sitemap": "node scripts/build-sitemap.js",
    "pipeline": "node scripts/orchestrator.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
